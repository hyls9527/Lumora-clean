{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumora",
  "version": "0.4.0",
  "identifier": "com.lumora.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lumora",
        "width": 960,
        "height": 700,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "theme": "Light",
        "backgroundColor": "#f2ede4"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' asset: https://asset.localhost; font-src 'self' https://fonts.gstatic.com; connect-src 'self' http://localhost:* https://localhost:* https://github.com ipc: tauri:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "languages": ["SimpChinese"],
        "installMode": "currentUser",
        "installerHooks": "nsis/installer-hooks.nsh"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/hyls9527/Lumora-clean/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVFQThGQ0E1NjlENzU2QjIKUldTeVZ0ZHBwZnlvN2hhN254bVJwcnJUVlViQ2VEZWl3dTMwbkJzM2kxaFZTOFVDODFxOTdlbE8K"
    }
  }
}
